<%- include('partials/head.ejs') %>

<div class="container-fluid mt-4 mb-5">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <%- include('sidebar') %>
        </div>
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2>Dashboard</h2>
                    <span class="text-muted">Tổng quan hệ thống</span>
                </div>
            </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-white bg-primary shadow border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Tổng Bài Viết</h5>
                    <h2 class="display-5 fw-bold mb-0"><%= stats.totalPosts %></h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <small>Số bài viết hiện có trong hệ thống</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-success shadow border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Tổng Danh Mục</h5>
                    <h2 class="display-5 fw-bold mb-0"><%= stats.totalCategories %></h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <small>Số chuyên mục đang hoạt động</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-dark bg-warning shadow border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Tổng Lượt Xem</h5>
                    <h2 class="display-5 fw-bold mb-0"><%= stats.totalViews %></h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <small class="text-dark">Tổng lượt truy cập các bài viết</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 fw-bold fs-5">
                    Thao tác nhanh
                </div>
                <div class="card-body py-4">
                    <a href="/admin/posts" class="btn btn-outline-primary px-4 py-2 me-2 mb-2">
                        Quản lý Bài viết
                    </a>
                    <a href="/admin/categories" class="btn btn-outline-success px-4 py-2 me-2 mb-2">
                        Quản lý Danh mục
                    </a>
                    <a href="/admin/posts/create" class="btn btn-primary px-4 py-2 mb-2 shadow-sm">+ Viết bài mới</a>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

<%- include('partials/footer.ejs') %>
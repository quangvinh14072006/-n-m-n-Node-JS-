<%- include('partials/head.ejs') %>

<div class="container-fluid mt-4 mb-5">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <%- include('sidebar') %>
        </div>
        <div class="col-lg-9">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h3><%= pageTitle %></h3>
                </div>
                <div class="card-body">
                    <form action="<%= action %>" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Tiêu đề</label>
                            <input type="text" class="form-control" name="title" required value="<%= post ? post.title : '' %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Danh mục</label>
                            <select name="category_id" class="form-select">
                                <option value="">Chọn danh mục</option>
                                <% categories.forEach((category) => { %>
                                    <option value="<%= category.id %>" <%= post && post.category_id == category.id ? 'selected' : '' %>><%= category.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nội dung</label>
                            <textarea name="content" class="form-control" rows="6"><%= post ? post.content : '' %></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Trạng thái</label>
                            <select name="status" class="form-select">
                                <option value="1" <%= post && post.status == 1 ? 'selected' : '' %>>Hoạt động</option>
                                <option value="0" <%= post && post.status == 0 ? 'selected' : '' %>>Bản nháp</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Lưu</button>
                        <a href="/admin/posts" class="btn btn-secondary ms-2">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer.ejs') %>
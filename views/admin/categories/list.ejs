<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 m-0">Danh mục</h1>
    <a href="/admin/categories/create" class="btn btn-primary">Thêm danh mục</a>
</div>
<div class="table-responsive bg-white shadow-sm rounded">
    <table class="table table-striped mb-0">
        <thead><tr><th>ID</th><th>Tên</th><th>Slug</th><th>Trạng thái</th><th></th></tr></thead>
        <tbody>
            <% (typeof categories !== 'undefined' ? categories : []).forEach(function(c) { %>
            <tr>
                <td><%= c.id %></td>
                <td><%= c.name %></td>
                <td><%= c.slug %></td>
                <td><%= c.status === 1 ? 'Hiển thị' : 'Ẩn' %></td>
                <td class="text-right">
                    <a href="/admin/categories/<%= c.id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
                    <form action="/admin/categories/<%= c.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Xóa danh mục này?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
</div>

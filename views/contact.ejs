<% const wi = typeof websiteInfo !== 'undefined' && websiteInfo ? websiteInfo : {}; %>
<section class="container-fluid mt-5 pt-3" aria-labelledby="contact-title">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <h1 id="contact-title" class="section-title mb-0 text-uppercase font-weight-bold">Liên hệ</h1>
                <% if (typeof contactFlash !== 'undefined' && contactFlash) { %>
                    <div class="alert alert-<%= contactFlash.type === 'success' ? 'success' : 'danger' %> mt-3" role="alert"><%= contactFlash.text %></div>
                <% } %>
                <div class="bg-white border border-top-0 p-4 mb-3">
                    <h2 class="h6 text-uppercase font-weight-bold">Thông tin</h2>
                    <% if (wi.address) { %><p><i class="fa fa-map-marker-alt text-primary mr-2"></i><%= wi.address %></p><% } %>
                    <% if (wi.email) { %><p><i class="fa fa-envelope-open text-primary mr-2"></i><a href="mailto:<%= wi.email %>"><%= wi.email %></a></p><% } %>
                    <% if (wi.phone) { %><p><i class="fa fa-phone-alt text-primary mr-2"></i><%= wi.phone %></p><% } %>
                    <h2 class="h6 text-uppercase font-weight-bold mt-4">Gửi tin nhắn</h2>
                    <form action="/lien-he" method="POST">
                        <div class="form-row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ct_name">Họ tên</label>
                                    <input type="text" class="form-control" id="ct_name" name="name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ct_email">Email</label>
                                    <input type="email" class="form-control" id="ct_email" name="email" required>
                                </div>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ct_phone">Điện thoại</label>
                                    <input type="text" class="form-control" id="ct_phone" name="phone">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ct_subject">Chủ đề</label>
                                    <input type="text" class="form-control" id="ct_subject" name="subject">
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="ct_message">Nội dung</label>
                            <textarea class="form-control" id="ct_message" name="message" rows="5" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-4">
                <%- include('partials/sidebar') %>
            </div>
        </div>
    </div>
</section>

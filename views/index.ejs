<article class="container-fluid pt-3 mb-3">
    <div class="container">
        <header class="section-title">
            <h2 class="m-0 text-uppercase font-weight-bold">Mới nhất</h2>
        </header>
        <div class="row">
            <% (typeof newestPosts !== 'undefined' ? newestPosts : []).slice(0,2).forEach(function(post) { %>
                <div class="col-lg-6"><%- include('partials/post-card', { post: post }) %></div>
            <% }); %>
        </div>
    </div>
</article>

<article class="container-fluid pt-3 mb-3">
    <div class="container">
        <header class="section-title">
            <h2 class="m-0 text-uppercase font-weight-bold">Xem nhiều nhất</h2>
        </header>
        <div class="row">
            <% (typeof popularPosts !== 'undefined' ? popularPosts : []).slice(0,4).forEach(function(post) { %>
                <div class="col-lg-3 col-md-6"><%- include('partials/post-card', { post: post }) %></div>
            <% }); %>
        </div>
    </div>
</article>

<% (typeof categoriesWithPosts !== 'undefined' ? categoriesWithPosts : []).forEach(function(block) { %>
<% if (block.posts && block.posts.length) { %>
<article class="container-fluid pt-3 mb-3">
    <div class="container">
        <header class="section-title d-flex justify-content-between align-items-center">
            <h2 class="m-0 text-uppercase font-weight-bold"><%= block.category.name %></h2>
            <a class="text-secondary font-weight-medium text-decoration-none" href="/tin-tuc?category_id=<%= block.category.id %>">Xem thêm</a>
        </header>
        <div class="row">
            <% block.posts.forEach(function(post) { %>
                <div class="col-lg-3 col-md-6"><%- include('partials/post-card', { post: post }) %></div>
            <% }); %>
        </div>
    </div>
</article>
<% } %>
<% }); %>

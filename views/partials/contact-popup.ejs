<div class="modal fade" id="contactPopupModal" tabindex="-1" role="dialog" aria-labelledby="contactPopupTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactPopupTitle">Liên hệ nhanh</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Đóng">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form action="/lien-he-popup" method="POST">
                <div class="modal-body">
                    <div class="form-row">
                        <div class="col-md-6 mb-3">
                            <label for="popup_name">Họ tên</label>
                            <input class="form-control" id="popup_name" name="name" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="popup_email">Email</label>
                            <input type="email" class="form-control" id="popup_email" name="email" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col-md-6 mb-3">
                            <label for="popup_phone">Điện thoại</label>
                            <input class="form-control" id="popup_phone" name="phone">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="popup_subject">Chủ đề</label>
                            <input class="form-control" id="popup_subject" name="subject">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="popup_message">Nội dung</label>
                        <textarea class="form-control" id="popup_message" name="message" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Gửi liên hệ</button>
                </div>
            </form>
        </div>
    </div>
</div>

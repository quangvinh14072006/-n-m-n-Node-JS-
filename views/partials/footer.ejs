<% const wi = typeof websiteInfo !== 'undefined' && websiteInfo ? websiteInfo : {}; %>
<footer class="site-footer" role="contentinfo">
<div class="container-fluid bg-dark pt-5 px-sm-3 px-md-5 mt-5">
    <div class="row py-4">
        <div class="col-lg-4 col-md-6 mb-5">
            <h5 class="mb-4 text-white text-uppercase font-weight-bold">Thông tin liên hệ</h5>
            <% if (wi.address) { %><p class="font-weight-medium text-white-50"><i class="fa fa-map-marker-alt mr-2" aria-hidden="true"></i><%= wi.address %></p><% } %>
            <% if (wi.phone) { %><p class="font-weight-medium text-white-50"><i class="fa fa-phone-alt mr-2" aria-hidden="true"></i><%= wi.phone %></p><% } %>
            <% if (wi.email) { %><p class="font-weight-medium text-white-50"><i class="fa fa-envelope mr-2" aria-hidden="true"></i><a class="text-white-50" href="mailto:<%= wi.email %>"><%= wi.email %></a></p><% } %>
            <h6 class="mt-4 mb-3 text-white text-uppercase font-weight-bold">Theo dõi</h6>
            <div class="d-flex justify-content-start">
                <% if (wi.facebook_link) { %>
                <a class="btn btn-lg btn-secondary btn-lg-square mr-2" href="<%= wi.facebook_link %>" rel="noopener noreferrer" target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <% } %>
                <% if (wi.youtube_link) { %>
                <a class="btn btn-lg btn-secondary btn-lg-square mr-2" href="<%= wi.youtube_link %>" rel="noopener noreferrer" target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                <% } %>
            </div>
            <button type="button" class="btn btn-outline-light btn-sm mt-3" data-toggle="modal" data-target="#contactPopupModal">Mở form liên hệ</button>
        </div>
        <div class="col-lg-4 col-md-6 mb-5">
            <h5 class="mb-4 text-white text-uppercase font-weight-bold">Đăng ký nhận tin</h5>
            <p class="text-white-50">Nhận thông báo khi có bài viết mới.</p>
            <form action="/dang-ky-nhan-tin" method="POST" class="form-inline flex-nowrap">
                <input type="email" name="email" class="form-control flex-grow-1 mr-2" placeholder="Email của bạn" required aria-label="Email đăng ký">
                <button class="btn btn-primary font-weight-bold" type="submit">Đăng ký</button>
            </form>
        </div>
        <div class="col-lg-4 col-md-12 mb-5">
            <h5 class="mb-4 text-white text-uppercase font-weight-bold">Danh mục</h5>
            <div class="m-n1">
                <% (typeof allCategories !== 'undefined' ? allCategories : []).forEach(function(c) { %>
                    <a href="/tin-tuc?category_id=<%= c.id %>" class="btn btn-sm btn-secondary m-1"><%= c.name %></a>
                <% }); %>
            </div>
        </div>
    </div>
</div>
<div class="container-fluid py-4 px-sm-3 px-md-5" style="background: #111111;">
    <p class="m-0 text-center text-white-50">
        <%= wi.copyright_text || '© BizNews' %>
        <span class="d-block d-md-inline"> · Design template: <a class="text-white-50" href="https://htmlcodex.com">HTML Codex</a></span>
    </p>
</div>
</footer>

<a href="#" class="btn btn-primary btn-square back-to-top" aria-label="Lên đầu trang"><i class="fa fa-arrow-up"></i></a>

<%- include('contact-popup') %>

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
<script src="/lib/easing/easing.min.js"></script>
<script src="/lib/owlcarousel/owl.carousel.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

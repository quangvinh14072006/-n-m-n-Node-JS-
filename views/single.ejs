<% 
  function imgSrc(p) {
    if (!p.image) return '/img/news-700x435-1.jpg';
    var t = String(p.image).trim();
    if (t.indexOf('http') === 0) return t;
    if (t.indexOf('/') === 0) return t;
    return '/' + t;
  }
  function fmt(d) {
    if (!d) return '';
    var x = new Date(d);
    return isNaN(x) ? '' : x.toLocaleString('vi-VN');
  }
%>
<div class="container-fluid">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <article class="position-relative mb-3" itemscope itemtype="https://schema.org/NewsArticle">
                    <img class="img-fluid w-100" src="<%= imgSrc(post) %>" alt="" itemprop="image" style="object-fit: cover; max-height: 420px;">
                    <div class="bg-white border border-top-0 p-4">
                        <header class="mb-3">
                            <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2" href="/tin-tuc?category_id=<%= post.category_id %>"><%= post.category_name %></a>
                            <time class="text-body" datetime="<%= post.created_at %>" itemprop="datePublished"><%= fmt(post.created_at) %></time>
                            <h1 class="mt-3 mb-0 text-secondary text-uppercase font-weight-bold" itemprop="headline"><%= post.title %></h1>
                        </header>
                        <div class="article-body ck-content" itemprop="articleBody">
                            <%- post.content %>
                        </div>
                    </div>
                    <footer class="d-flex justify-content-between bg-white border border-top-0 p-4">
                        <div class="d-flex align-items-center" itemprop="author" itemscope itemtype="https://schema.org/Person">
                            <img class="rounded-circle mr-2" src="/img/user.jpg" width="25" height="25" alt="">
                            <span itemprop="name"><%= post.author_name %></span>
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="ml-3"><i class="far fa-eye mr-2" aria-hidden="true"></i><%= post.views || 0 %></span>
                        </div>
                    </footer>
                </article>

                <section class="mb-3" aria-labelledby="related-title">
                    <div class="section-title mb-0">
                        <h2 id="related-title" class="m-0 text-uppercase font-weight-bold">Bài viết liên quan</h2>
                    </div>
                    <div class="bg-white border border-top-0 p-4">
                        <div class="row">
                            <% (typeof related !== 'undefined' ? related : []).forEach(function(rp) { %>
                                <div class="col-md-6 mb-3"><%- include('partials/post-card', { post: rp }) %></div>
                            <% }); %>
                        </div>
                    </div>
                </section>

                <section class="mb-3" id="binh-luan" aria-labelledby="comments-title">
                    <div class="section-title mb-0">
                        <h2 id="comments-title" class="m-0 text-uppercase font-weight-bold">Bình luận (<%= (typeof comments !== 'undefined' ? comments : []).length %>)</h2>
                    </div>
                    <div class="bg-white border border-top-0 p-4">
                        <% (typeof comments !== 'undefined' ? comments : []).forEach(function(c) { %>
                            <div class="media mb-4 border-bottom pb-3">
                                <div class="media-body">
                                    <h3 class="h6 mb-1"><span class="text-secondary font-weight-bold"><%= c.email %></span>
                                        <small class="text-muted"><%= fmt(c.created_at) %></small></h3>
                                    <p class="mb-0"><%= c.content %></p>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </section>

                <section class="mb-5" aria-labelledby="leave-comment-title">
                    <div class="section-title mb-0">
                        <h2 id="leave-comment-title" class="m-0 text-uppercase font-weight-bold">Gửi bình luận</h2>
                    </div>
                    <div class="bg-white border border-top-0 p-4">
                        <% if (typeof commentError !== 'undefined' && commentError) { %>
                            <div class="alert alert-danger" role="alert"><%= commentError %></div>
                        <% } %>
                        <form method="POST" action="/bai-viet/<%= post.id %>/binh-luan">
                            <div class="form-group">
                                <label for="c_email">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="c_email" name="email" required>
                            </div>
                            <div class="form-group">
                                <label for="c_content">Nội dung <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="c_content" name="content" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Gửi bình luận</button>
                        </form>
                    </div>
                </section>
            </div>
            <div class="col-lg-4">
                <%- include('partials/sidebar') %>
            </div>
        </div>
    </div>
</div>
